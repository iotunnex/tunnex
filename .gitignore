# Env & secrets (never commit)
.env
.env.local
*.local
# Runtime secrets material only — ROOT-ANCHORED so it never eats the
# apps/api/internal/secrets SOURCE package (that unanchored `secrets/` silently
# kept the S0.3 crypto code out of git and broke every fresh clone / CI build).
/secrets/
/data/

