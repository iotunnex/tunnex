# Tunnex.io environment. Copy to .env (`make up` does this automatically).
# First-boot bootstrap (S0.3) will auto-generate real secrets; these are dev defaults.

# --- Core ---
TUNNEX_ENV=development
TUNNEX_LOG_LEVEL=info

# --- Postgres ---
POSTGRES_USER=tunnex
POSTGRES_PASSWORD=tunnex_dev_password
POSTGRES_DB=tunnex
# Consumed by the API (wired to the DB in EPIC 1).
DATABASE_URL=postgres://tunnex:tunnex_dev_password@postgres:5432/tunnex?sslmode=disable

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- API ---
TUNNEX_API_ADDR=:8080
# Public base URL for email links (verify email, password reset, invites). The
# localhost default ONLY works when the browser runs on the same host — on a remote
# deploy set this to the server's public URL (e.g. https://tunnex.example.com), or
# email links will be unreachable. The API warns loudly at boot if left at localhost.
APP_BASE_URL=http://localhost

# --- Node agent ---
TUNNEX_API_URL=http://api:8080
# One-time join token exchanged for an mTLS cert in S3.1 (empty for the stub).
TUNNEX_JOIN_TOKEN=

# --- Mail (S2.1 flows; dev uses Mailpit) ---
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_FROM=no-reply@tunnex.local

# --- WireGuard data plane (node agent) ---
# Public endpoint (host:port) that client configs dial to reach this gateway.
# MUST be reachable by your clients: set it to the node's public IP/hostname and
# published WG UDP port in production (e.g. vpn.example.com:51820). The compose
# default uses the container service name, which works for on-network clients.
# TUNNEX_NODE_ENDPOINT=vpn.example.com:51820

# --- Secrets ---
# The master encryption key, session secret, and WireGuard server key are
# auto-generated on first boot and persisted (0600) on the dedicated
# `tunnex_secrets` volume at TUNNEX_SECRETS_DIR. They are NOT set via env.
# Override the location only if you know what you are doing:
# TUNNEX_SECRETS_DIR=/var/lib/tunnex/secrets
