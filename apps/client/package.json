{
  "name": "@tunnex/client",
  "version": "0.1.0",
  "private": true,
  "description": "Tunnex desktop client (Electron)",
  "main": "dist/main/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "electron .",
    "stage:helper": "bash scripts/stage-helper.sh",
    "pack": "bash scripts/pack.sh",
    "pack:mac": "bash scripts/pack.sh mac",
    "pack:win": "bash scripts/pack.sh win",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --require ts-node/register --test test/core.test.ts test/security.test.ts test/tunnel.test.ts test/deviceconfig.test.ts test/revocation.test.ts test/uxwiring.test.ts test/httpdeviceapi.test.ts test/helperinstall.test.ts test/quitguard.test.ts"
  },
  "dependencies": {
    "electron-log": "5.2.0",
    "electron-store": "8.2.0",
    "electron-updater": "6.3.9"
  },
  "devDependencies": {
    "@types/node": "20.14.0",
    "electron": "31.7.7",
    "electron-builder": "25.1.8",
    "ts-node": "10.9.2",
    "typescript": "5.5.4"
  }
}
