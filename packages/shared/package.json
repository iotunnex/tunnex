{
  "name": "@tunnex/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "description": "Shared TypeScript types + typed API client, generated from the OpenAPI spec.",
  "scripts": {
    "generate": "openapi-typescript ../../openapi/openapi.yaml -o src/api.d.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "openapi-fetch": "^0.13.0"
  },
  "devDependencies": {
    "openapi-typescript": "^7.4.4",
    "typescript": "^5.6.3"
  }
}
